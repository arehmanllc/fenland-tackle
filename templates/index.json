          }
        },
        "richtext_3WgqLw": {
          "type": "richtext",
          "settings": {
            "content": "<p>Fenland Tackle Exchange was formed to give anglers in East Anglia and beyond a fairer way to buy, sell, and trade-in dependable fishing tackle, bait and clothing - curating new and pre-owned gear you can trust, based on many decades’ carp and coarse fishing experience. Our goal is to help anglers throughout the Fenland region (and the UK as a whole) to access new and used tackle, bait and clothing that has stood the test of time.</p>"
          }
        },
        "liquid_QRgMq7": {
