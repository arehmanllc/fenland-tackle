    "faq_m9BNCh": {
      "type": "faq",
      "blocks": {
        "question_ghmFeb": {
          "type": "question",
          "settings": {
            "question": "What type of fishing tackle do you sell at Fenland Tackle Exchange?",
            "light_background": true,
            "answer": "<p>We offer a wide range of freshwater fishing tackle, including rods, reels, carp fishing tackle, predator gear, coarse fishing essentials, specimen fishing tackle, bite alarms, luggage, and more—all from dependable, lesser-known brands at affordable prices.</p>"
          }
        },
        "question_QU6hCU": {
          "type": "question",
          "settings": {
            "question": "How can I sell my pre-owned fishing tackle with Fenland Tackle Exchange?",
            "light_background": false,
            "answer": "<p>You can easily sell your fishing tackle by filling out our seller enquiry form. We buy job lots of pre-owned fishing gear, particularly complete carp set-ups, to help you upgrade your kit or make extra cash.<br/></p>"
          }
        },
        "question_j6GBdV": {
          "type": "question",
          "settings": {
            "question": "What makes your fishing bait more affordable?",
            "light_background": true,
            "answer": "<p>We source quality bait from lesser-known brands, allowing anglers to obtain dependable options without the high price tag. Our affordable fishing bait is perfect for carp, coarse, and predator fishing.<br/></p>"
          }
        },
        "question_bqjD6f": {
          "type": "question",
          "settings": {
            "question": "Do you buy complete carp set-ups?",
            "light_background": false,
            "answer": "<p>Yes! At Fenland Tackle Exchange, we specialise in buying complete carp set-ups and other fishing tackle. This is a great way for you to upgrade your kit while getting fair prices for your pre-owned gear.<br/></p>"
          }
        },
        "question_qck4n7": {
          "type": "question",
          "settings": {
            "question": "How do you ensure the quality of your fishing tackle?",
            "light_background": true,
            "answer": "<p>We only sell fishing tackle and bait that our team personally uses and depends on. Our hands-on experience allows us to curate a selection of reliable products that meet the needs of anglers at all levels.<br/></p>"
          }
        },
        "question_d68Ngh": {
          "type": "question",
          "settings": {
            "question": "Can I trade my old fishing gear for new tackle?",
            "light_background": false,
            "answer": "<p>Yes! We offer a straightforward selling process where you can trade your pre-owned fishing gear, allowing you to invest in new tackle while clearing out what you no longer need.<br/></p>"
          }
        },
        "question_dk4CtB": {
          "type": "question",
          "settings": {
            "question": "What additional fishing accessories do you carry?",
            "light_background": true,
            "answer": "<p>Along with fishing tackle, we carry a variety of fishing accessories, including rod pods, metalware, bivvies, shelters, mats, slings, scales, cooking equipment, and more to enhance your fishing experience.<br/><br/></p>"
          }
        },
        "question_gAqTGH": {
          "type": "question",
          "settings": {
            "question": "Are your prices competitive compared to other tackle shops?",
            "light_background": false,
            "answer": "<p>Absolutely! Fenland Tackle Exchange is dedicated to providing anglers with some of the best deals on affordable fishing tackle in the UK. Our competitive pricing makes it easy for you to find reliable gear without overspending.<br/></p>"
          }
        },
        "question_AYJUpf": {
          "type": "question",
          "settings": {
            "question": "How can I contact you for more information?",
            "light_background": true,
            "answer": "<p>If you have further questions about our fishing tackle or the selling process, you can reach out via our <a href=\"https://fenlandtacklestore.co.uk/pages/contact\" target=\"_blank\">contact form </a>on the website, or you can call our customer service team directly.<br/></p>"
          }
        },
        "question_rVjqxQ": {
          "type": "question",
          "settings": {
            "question": "What is your returns policy on fishing tackle purchases?",
            "light_background": false,
            "answer": "<p>We want you to be completely satisfied with your purchase. Please refer to our Returns Policy on our website for detailed information on returns and exchanges of any fishing tackle you buy.<br/></p>"
          }
        },
        "question_iWwaHn": {
          "type": "question",
          "settings": {
            "question": "Can I find reviews of your fishing tackle online?",
            "light_background": true,
            "answer": "<p>Yes! Check our website for customer reviews and testimonials on various tackle and bait products. Our community of anglers shares their experiences to help you make informed purchasing decisions.<br/></p>"
          }
        }
      },
